{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "types": [
      "node",
      "reflect-metadata"
    ],
    "lib": [
      "ES2020",
      "DOM"
    ],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@server/*": [
        "server/*"
      ],
    }
  },
  "include": [
    "index.ts",
    "akigumo/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}