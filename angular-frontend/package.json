{
  "name": "angular-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:angular-frontend": "node dist/angular-frontend/server/server.mjs",
    "api:gen": "openapi-generator-cli generate -i http://localhost:3000/api/v1/doc -g typescript-angular -o src/app/api/generated"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/cdk": "^21.1.5",
    "@angular/common": "^21.1.5",
    "@angular/compiler": "^21.1.5",
    "@angular/core": "^21.1.5",
    "@angular/forms": "^21.1.5",
    "@angular/material": "^21.1.5",
    "@angular/platform-browser": "^21.1.5",
    "@angular/platform-server": "^21.1.5",
    "@angular/router": "^21.1.5",
    "@angular/ssr": "^21.1.5",
    "@jjmhalew/ngx-lightbox": "^21.0.0",
    "@ngrx/signals": "^21.0.1",
    "@primeng/themes": "^21.0.2",
    "@primeuix/themes": "^2.0.2",
    "express": "^5.1.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.5",
    "@angular/cli": "^21.1.5",
    "@angular/compiler-cli": "^21.1.5",
    "@faker-js/faker": "^10.3.0",
    "@openapitools/openapi-generator-cli": "^2.28.2",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^20.17.19",
    "autoprefixer": "^10.4.22",
    "jsdom": "^27.1.0",
    "msw": "^2.12.10",
    "orval": "^8.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}