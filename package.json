{
  "name": "kpptrproject",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev:backend": "tsx akigumo/index.ts",
    "dev:frontend": "npm --prefix angular-frontend run start -- --host 127.0.0.1 --poll 2000",
    "dev:file-graph": "set -a && . ./.env && set +a && .venv/bin/python akigumo/services/graph-refinement-engine/python/graph_refine_worker.py",
    "dev:all": "concurrently -k -n backend,frontend,file-graph -c blue,green,magenta \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:file-graph\"",
    "prisma:combine": "cat prisma/schemas/*.prisma > prisma/schema.prisma",
    "prisma:generate": "npm run prisma:combine && prisma generate",
    "prisma:migrate:dev": "npm run prisma:combine && prisma migrate dev",
    "prisma:studio": "npm run prisma:combine && prisma studio",
    "test": "jest",
    "start:sync-worker": "ts-node server/workers/syncWorker.ts"
  },
